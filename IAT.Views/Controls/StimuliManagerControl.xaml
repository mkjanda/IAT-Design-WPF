<UserControl x:Class="IAT.Views.Controls.StimuliManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:IAT.ViewModels.Controls;assembly=IAT.ViewModels"
             xmlns:conv="clr-namespace:IAT.ViewModels.Converters;assembly=IAT.ViewModels"
             xmlns:local="clr-namespace:IAT.Views.Controls"
             xmlns:domain="clr-namespace:IAT.Core.Domain;assembly=IAT.Core"
             Background="#1E1E1E">

    <UserControl.Resources>
        <conv:StimulusEditTemplateSelector x:Key="StimulusEditSelector">
            <conv:StimulusEditTemplateSelector.TextEditTemplate>
                <DataTemplate>
                    <local:TextStimulusEditControl DataContext="{Binding}"/>
                </DataTemplate>
            </conv:StimulusEditTemplateSelector.TextEditTemplate>
            <conv:StimulusEditTemplateSelector.ImageEditTemplate>
                <DataTemplate>
                    <local:ImageStimulusEditControl DataContext="{Binding}"/>
                </DataTemplate>
            </conv:StimulusEditTemplateSelector.ImageEditTemplate>
        </conv:StimulusEditTemplateSelector>

        <!-- Simple DataTemplate for domain Stimulus objects in the ListBox -->
        <DataTemplate DataType="{x:Type domain:TextStimulus}">
            <StackPanel Orientation="Horizontal" Margin="4,6">
                <TextBlock Text="T" FontWeight="Bold" Foreground="#00BFA5"
                           Width="20" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Text}" Foreground="#E0E0E0"
                           TextTrimming="CharacterEllipsis" MaxWidth="220"
                           VerticalAlignment="Center" ToolTip="{Binding Text}"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type domain:ImageStimulus}">
            <StackPanel Orientation="Horizontal" Margin="4,6">
                <TextBlock Text="I" FontWeight="Bold" Foreground="#F7C46C"
                           Width="20" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding FileName}" Foreground="#E0E0E0"
                           TextTrimming="CharacterEllipsis" MaxWidth="220"
                           VerticalAlignment="Center" ToolTip="{Binding FileName}"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <!-- List -->
            <ColumnDefinition Width="*"/>
            <!-- Edit Panel -->
        </Grid.ColumnDefinitions>

        <!-- LEFT: Stimuli List bound to the singleton IatTest.Stimuli -->
        <Border Grid.Column="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock Text="Stimuli" FontSize="16" FontWeight="SemiBold" 
                           Foreground="#FFFFFF" Margin="12,10" DockPanel.Dock="Top"/>

                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="8,0,8,8" Padding="8,6"
                         Background="#2D2D2D" BorderBrush="#3C3C3C" Foreground="#CCCCCC"
                         Tag="Search stimuli..." DockPanel.Dock="Top"/>

                <!-- 
                    Bind to DisplayedStimuli which always points at either the live
                    IatTest.Stimuli ObservableCollection or a filtered snapshot.
                    Add/Update/Remove on the domain collection therefore appear immediately.
                -->
                <ListBox ItemsSource="{Binding DisplayedStimuli}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Margin="4,0,4,4" DockPanel.Dock="Top">
                    <!-- DataTemplates above handle rendering per concrete Stimulus type -->
                </ListBox>

                <StackPanel Orientation="Vertical" Margin="8" DockPanel.Dock="Bottom">
                    <Button Content="+ Add Text Stimulus" 
                            Command="{Binding AddTextStimulusCommand}"
                            Style="{StaticResource AccentButton}" Width="auto" Height="36" Margin="0,0,0,8"/>
                    <Button Content="+ Add Image Stimulus" 
                            Command="{Binding AddImageStimulusCommand}"
                            Style="{StaticResource AccentButton}" Width="auto" Height="36" Margin="0,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- RIGHT: Dynamic Edit Panel -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentEditViewModel}"
                        ContentTemplateSelector="{StaticResource StimulusEditSelector}"
                        Margin="16"/>
    </Grid>
</UserControl>
