<UserControl x:Class="IAT.Views.Controls.StimuliManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:IAT.ViewModels.Controls;assembly=IAT.ViewModels"
             xmlns:local="clr-namespace:IAT.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="280"
             Background="#1E1E1E">

    <UserControl.DataContext>
        <vm:StimuliManagerViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Search -->
            <RowDefinition Height="*"/>
            <!-- List -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header (matches Blocks panel) -->
        <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="12,10">
            <TextBlock Text="Stimuli" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF"/>
        </Border>

        <!-- Search (exact match to screenshot) -->
        <TextBox Grid.Row="1" 
                 Margin="8,8,8,4" Padding="8,6"
                 Background="#2D2D2D" BorderBrush="#3C3C3C" Foreground="#CCCCCC"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Tag="Search stimuli..."/>

        <!-- Stimuli List -->
        <ListBox Grid.Row="2" Margin="4,0,4,4"
                 Background="Transparent" BorderThickness="0"
                 ItemsSource="{Binding StimuliItems}"
                 SelectedItem="{Binding SelectedItem}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:StimulusListItemViewModel}">
                    <Border Margin="4,2" Background="#2D2D2D" CornerRadius="4" Padding="8"
                            BorderBrush="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource SelectedBorderConverter}}"
                            BorderThickness="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Preview thumbnail -->
                            <Border Width="52" Height="52" Background="#1E1E1E" CornerRadius="3" Margin="0,0,12,0">
                                <Image Source="{Binding Preview}" Stretch="Uniform" Margin="4"/>
                            </Border>

                            <!-- Text info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" 
                                           Foreground="#D4D4D4" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding StimulusType}" 
                                           Foreground="#888888" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Blue Add buttons (exact style of your + Add Block) -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="8">
            <Button Content="+ Add Text Stimulus"
                    Command="{Binding AddTextStimulusCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    Width="138" Height="36" Margin="0,0,8,0"/>
            <Button Content="+ Add Image Stimulus"
                    Command="{Binding AddImageStimulusCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    Width="138" Height="36"/>
        </StackPanel>
    </Grid>
</UserControl>