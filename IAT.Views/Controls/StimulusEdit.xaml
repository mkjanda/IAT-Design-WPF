<UserControl x:Class="IAT.Views.Controls.StimulusEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IAT.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="1000">
    <Grid>

        <!-- Stimuli Tab Content -->
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <!-- Stimuli Library -->
                <ColumnDefinition Width="*" />
                <!-- Edit panel -->
            </Grid.ColumnDefinitions>

            <!-- 1. LEFT: Stimuli Library -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0" Padding="8">
                <DockPanel>
                    <TextBlock Text="Stimuli Library" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12" DockPanel.Dock="Top"/>

                    <!-- Search -->
                    <TextBox Text="Aaatch" 
                                     Margin="0,0,0,12"
                                     Background="#2D2D2D"
                                     BorderBrush="#3C3C3C"
                                     Foreground="#CCCCCC"
                                     Padding="8,6"
                                     DockPanel.Dock="Bottom"/>

                    <!-- Library List -->
                    <ListBox Background="Transparent" BorderThickness="0" 
                                     ItemsSource="{Binding StimuliLibrary}" 
                                     SelectedItem="{Binding SelectedStimulus}">
                        <!-- Item template would go here – you can expand with your icons -->
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <Image Source="{Binding Icon}" Width="24" Height="24" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>


            <!-- 3. RIGHT: Edit Text Stimulus Panel -->
            <Border Grid.Column="1" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1,0,0,0" Padding="16"
                    Visibility="{Binding IsEditPanelVisible}">
                <DockPanel>
                    <!-- Header -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                        <TextBlock Text="Edit Text Stimulus" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Content="✕" HorizontalAlignment="Right" 
                                        Background="Transparent" BorderThickness="0" Foreground="#888" FontSize="18"
                                        Width="28" Height="28" Click="CloseEditPanel"/>
                    </DockPanel>

                    <!-- TextBox -->
                    <TextBox Text="TextBox Stimulus text edimus stimuly, Edit, alvs Stimuli TextBox."
                                     Margin="0,0,0,16"
                                     Background="#2D2D2D"
                                     BorderBrush="#555"
                                     Foreground="#E0E0E0"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Height="120"
                                     VerticalContentAlignment="Top"
                                     DockPanel.Dock="Top"/>

                    <!-- Font controls -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,24,0">
                            <TextBlock Text="Font Family" FontSize="12" Margin="0,0,0,4"/>
                            <ComboBox Width="140" SelectedIndex="0">
                                <ComboBoxItem>Arial</ComboBoxItem>
                                <ComboBoxItem>Segoe UI</ComboBoxItem>
                                <ComboBoxItem>Calibri</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,24,0">
                            <TextBlock Text="Font Size" FontSize="12" Margin="0,0,0,4"/>
                            <ComboBox Width="80" SelectedIndex="3">
                                <ComboBoxItem>12 pt</ComboBoxItem>
                                <ComboBoxItem>18 pt</ComboBoxItem>
                                <ComboBoxItem>24 pt</ComboBoxItem>
                                <ComboBoxItem>36 pt</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Color" FontSize="12" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="28" Height="28" Fill="#FF0000" Margin="2" Stroke="#555"/>
                                <Rectangle Width="28" Height="28" Fill="#00FF00" Margin="2" Stroke="#555"/>
                                <Rectangle Width="28" Height="28" Fill="#0000FF" Margin="2" Stroke="#555"/>
                                <Rectangle Width="28" Height="28" Fill="#000000" Margin="2" Stroke="#555"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Preview -->
                    <Border BorderBrush="#444" BorderThickness="1" Background="White" 
                                    Margin="0,0,0,16" Padding="20" DockPanel.Dock="Top">
                        <TextBlock Text="Black" FontSize="72" FontWeight="Bold" 
                                           Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Bottom">
                        <Button Content="Save" Width="100" Height="38" Margin="0,0,8,0"
                                        Background="#007ACC" Foreground="White" FontWeight="SemiBold"/>
                        <Button Content="Delete Stimulus" Width="140" Height="38" Margin="0,0,8,0"
                                        Background="#252526" BorderBrush="#666" Foreground="#E0E0E0"/>
                        <Button Content="+ Add New Stimulus" Width="160" Height="38"
                                        Background="#00BFA5" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>            
    </Grid>
</UserControl>
