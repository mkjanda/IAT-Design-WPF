<UserControl x:Class="IAT.Views.Controls.TextStimulusEditControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="520"
             Background="#252526">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="Auto"/>
            <!-- Action buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Edit Text Stimulus" 
                       FontSize="18" FontWeight="SemiBold" 
                       Foreground="#FFFFFF" VerticalAlignment="Center"/>
            <Button Content="✕" 
                    HorizontalAlignment="Right"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#888888" FontSize="20"
                    Width="32" Height="32"
                    Command="{Binding CloseCommand}"/>
        </DockPanel>

        <!-- Main Edit Area -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Text input -->
                <RowDefinition Height="Auto"/>
                <!-- Font controls -->
                <RowDefinition Height="*"/>
                <!-- Preview -->
            </Grid.RowDefinitions>

            <!-- Stimulus Text -->
            <TextBox Grid.Row="0"
                     Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DarkTextBox}"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     Height="120" Margin="0,0,0,16"
                     FontSize="14"/>

            <!-- Font Controls -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Font Family -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <TextBlock Text="Font Family" FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                    <ComboBox Width="160" 
                              ItemsSource="{Binding AvailableFontFamilies}"
                              SelectedItem="{Binding FontFamily}"
                              Style="{StaticResource DarkComboBox}"/>
                </StackPanel>

                <!-- Font Size -->
                <StackPanel Grid.Column="1" Margin="0,0,24,0">
                    <TextBlock Text="Font Size" FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                    <ComboBox Width="90"
                              ItemsSource="{Binding AvailableFontSizes}"
                              SelectedItem="{Binding FontSize}"
                              Style="{StaticResource DarkComboBox}"/>
                </StackPanel>

                <!-- Color Palette -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Color" FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Width="32" Height="32" Margin="2" 
                                Command="{Binding ApplyPaletteCommand}" CommandParameter="Black"
                                Background="#000000" BorderBrush="#555"/>
                        <Button Width="32" Height="32" Margin="2"
                                Command="{Binding ApplyPaletteCommand}" CommandParameter="White"
                                Background="#FFFFFF" BorderBrush="#555"/>
                        <Button Width="32" Height="32" Margin="2"
                                Command="{Binding ApplyPaletteCommand}" CommandParameter="Pleasant"
                                Background="#00BFA5" BorderBrush="#555"/>
                        <Button Width="32" Height="32" Margin="2"
                                Command="{Binding ApplyPaletteCommand}" CommandParameter="Unpleasant"
                                Background="#DC3232" BorderBrush="#555"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Live Preview -->
            <Border Grid.Row="2" 
                    Background="White" 
                    BorderBrush="#444444" BorderThickness="1"
                    CornerRadius="4" Padding="20">
                <TextBlock Text="{Binding Text}"
                           FontFamily="{Binding FontFamily}"
                           FontSize="{Binding FontSize}"
                           Foreground="{Binding PreviewBrush}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Width="100" Height="38" Margin="0,0,8,0"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding SaveCommand}"/>
            <Button Content="Delete Stimulus" Width="140" Height="38" Margin="0,0,8,0"
                    Background="#3C3C3C" Foreground="#E0E0E0"
                    Command="{Binding DeleteCommand}"/>
            <Button Content="+ Add New Stimulus" Width="160" Height="38"
                    Background="#00BFA5" Foreground="White" FontWeight="SemiBold"
                    Command="{Binding AddNewCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>