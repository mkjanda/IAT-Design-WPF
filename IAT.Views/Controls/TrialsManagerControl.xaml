<UserControl x:Class="IAT.Views.Controls.TrialsManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:domain="clr-namespace:IAT.Core.Domain;assembly=IAT.Core"
             xmlns:vm="clr-namespace:IAT.ViewModels.Controls;assembly=IAT.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="DarkLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Stimulus display in ComboBox -->
        <DataTemplate x:Key="StimulusComboTemplate" DataType="{x:Type domain:Stimulus}">
            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- ========== LEFT: Blocks list ========== -->
        <Border Grid.Column="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock Text="Blocks" FontSize="16" FontWeight="SemiBold"
                           Foreground="#FFFFFF" Margin="12,10" DockPanel.Dock="Top"/>

                <ListBox ItemsSource="{Binding Blocks}"
                         SelectedItem="{Binding SelectedBlock, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         Margin="4,0,4,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="6,8">
                                <TextBlock Text="{Binding Name}" Foreground="#E0E0E0"
                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Foreground="#888888" FontSize="11" Margin="0,2,0,0">
                                    <Run Text="Block "/>
                                    <Run Text="{Binding BlockNumber, Mode=OneWay}"/>
                                    <Run Text="  ·  "/>
                                    <Run Text="{Binding NumPresentations, Mode=OneWay}"/>
                                    <Run Text=" trials"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ========== CENTER: Trials + Keys for selected block ========== -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header + NumPresentations + Response Keys -->
            <StackPanel Grid.Row="0">
                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="{Binding SelectedBlock.Name, FallbackValue='Select a block'}"
                               FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Number of Trials" Style="{StaticResource DarkLabel}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding NumPresentations, UpdateSourceTrigger=PropertyChanged}"
                                 Width="70" Height="32" Padding="6,4"
                                 Background="#2D2D2D" Foreground="#E0E0E0"
                                 BorderBrush="#555555" VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </DockPanel>

                <!-- Response Keys card -->
                <Border Background="#2A2A2A" BorderBrush="#3C3C3C" BorderThickness="1"
                        CornerRadius="4" Padding="12" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Left Response Key" Style="{StaticResource SectionHeader}"/>
                            <TextBox Text="{Binding LeftKeyText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}"
                                     Height="36" Padding="8,6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Right Response Key" Style="{StaticResource SectionHeader}"/>
                            <TextBox Text="{Binding RightKeyText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}"
                                     Height="36" Padding="8,6"/>
                        </StackPanel>

                        <Button Grid.Column="3" Content="Save Keys"
                                Command="{Binding SaveKeysCommand}"
                                Style="{StaticResource AccentButton}"
                                Width="100" Height="36" Margin="16,20,0,0"
                                VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Trials list -->
            <Border Grid.Row="1" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                    CornerRadius="4">
                <DockPanel>
                    <TextBlock Text="Trials (Stimulus + Keying)" Style="{StaticResource SectionHeader}"
                               Margin="12,10,12,4" DockPanel.Dock="Top"/>

                    <!-- Column headers -->
                    <Grid Margin="12,0,12,4" DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" Foreground="#888" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="Stimulus" Foreground="#888" FontSize="11"/>
                        <TextBlock Grid.Column="2" Text="Key Direction" Foreground="#888" FontSize="11"/>
                    </Grid>

                    <ListBox ItemsSource="{Binding Trials}"
                             SelectedItem="{Binding SelectedTrial, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             Margin="4" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TrialRowViewModel}">
                                <Grid Margin="4,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Trial # -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TrialNumber}"
                                               Foreground="#888888"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>

                                    <!-- Stimulus selector -->
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding DataContext.AvailableStimuli, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedItem="{Binding SelectedStimulus, Mode=TwoWay}"
                                              Style="{StaticResource DarkComboBox}"
                                              Margin="0,0,12,0"
                                              Height="32">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <!-- Keyed direction -->
                                    <ComboBox Grid.Column="2"
                                              ItemsSource="{x:Static vm:TrialRowViewModel.DirectionOptions}"
                                              SelectedItem="{Binding DirectionName, Mode=TwoWay}"
                                              Style="{StaticResource DarkComboBox}"
                                              Height="32"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Action buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="+ Add Trial"
                        Command="{Binding AddTrialCommand}"
                        Style="{StaticResource AccentButton}"
                        Height="36" Width="110" Margin="0,0,8,0"/>
                <Button Content="Clear Trials"
                        Command="{Binding ClearTrialsCommand}"
                        Background="#3C3C3C" Foreground="#E0E0E0"
                        Height="36" Width="110" Margin="0,0,8,0"/>
                <Button Content="Remove Selected"
                        Command="{Binding RemoveSelectedTrialCommand}"
                        Background="#3C3C3C" Foreground="#E0E0E0"
                        Height="36" Width="130"/>
            </StackPanel>
        </Grid>

        <!-- ========== RIGHT: Available Stimuli for quick assignment ========== -->
        <Border Grid.Column="2" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1,0,0,0">
            <DockPanel>
                <TextBlock Text="Assign Stimuli" FontSize="16" FontWeight="SemiBold"
                           Foreground="#FFFFFF" Margin="12,10" DockPanel.Dock="Top"/>

                <TextBlock Text="Click L / R to add a trial keyed that way for the selected block."
                           TextWrapping="Wrap" Foreground="#888888" FontSize="11"
                           Margin="12,0,12,8" DockPanel.Dock="Top"/>

                <ListBox ItemsSource="{Binding AvailableStimuli}"
                         Background="Transparent" BorderThickness="0"
                         Margin="4,0,4,8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2A2A2A" CornerRadius="4" Padding="8" Margin="4,3">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Button Content="L" Width="28" Height="28" Margin="0,0,4,0"
                                                Background="#007ACC" Foreground="White" FontWeight="Bold"
                                                ToolTip="Assign as Left-keyed trial"
                                                Tag="{Binding}"
                                                Click="OnAssignLeftClick"/>
                                        <Button Content="R" Width="28" Height="28"
                                                Background="#C586C0" Foreground="White" FontWeight="Bold"
                                                ToolTip="Assign as Right-keyed trial"
                                                Tag="{Binding}"
                                                Click="OnAssignRightClick"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding}" 
                                               Foreground="#E0E0E0"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               ToolTip="{Binding}"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
