<UserControl x:Class="IAT.Views.Controls.SurveyManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:domain="clr-namespace:IAT.Core.Domain;assembly=IAT.Core"
             xmlns:vm="clr-namespace:IAT.ViewModels.Controls;assembly=IAT.ViewModels"
             xmlns:conv="clr-namespace:IAT.ViewModels.Converters;assembly=IAT.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#1E1E1E">

    <UserControl.Resources>

        <!-- Item type badges -->
        <DataTemplate DataType="{x:Type domain:SurveyHeader}">
            <DockPanel Margin="4,6">
                <Border Background="#F7C46C" CornerRadius="3" Padding="6,2" DockPanel.Dock="Left" Margin="0,0,8,0">
                    <TextBlock Text="HDR" FontSize="10" FontWeight="Bold" Foreground="#1E1E1E"/>
                </Border>
                <TextBlock Text="{Binding Text}" Foreground="#E0E0E0" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" ToolTip="{Binding Text}"/>
            </DockPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type domain:SurveyInstruction}">
            <DockPanel Margin="4,6">
                <Border Background="#007ACC" CornerRadius="3" Padding="6,2" DockPanel.Dock="Left" Margin="0,0,8,0">
                    <TextBlock Text="INS" FontSize="10" FontWeight="Bold" Foreground="White"/>
                </Border>
                <TextBlock Text="{Binding Text}" Foreground="#E0E0E0" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" ToolTip="{Binding Text}"/>
            </DockPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type domain:SurveyImage}">
            <DockPanel Margin="4,6">
                <Border Background="#C586C0" CornerRadius="3" Padding="6,2" DockPanel.Dock="Left" Margin="0,0,8,0">
                    <TextBlock Text="IMG" FontSize="10" FontWeight="Bold" Foreground="White"/>
                </Border>
                <TextBlock Text="Image" Foreground="#E0E0E0" VerticalAlignment="Center"/>
            </DockPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type domain:SurveyQuestion}">
            <DockPanel Margin="4,6">
                <Border Background="#4EC9B0" CornerRadius="3" Padding="6,2" DockPanel.Dock="Left" Margin="0,0,8,0">
                    <TextBlock Text="Q" FontSize="10" FontWeight="Bold" Foreground="#1E1E1E"/>
                </Border>
                <TextBlock Text="{Binding Text}" Foreground="#E0E0E0" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" ToolTip="{Binding Text}"/>
            </DockPanel>
        </DataTemplate>

        <!-- ── Response definition editors (bound via ContentControl to CurrentResponse) ── -->

        <DataTemplate DataType="{x:Type domain:LikertResponse}">
            <StackPanel>
                <TextBlock Text="Likert Scale" Foreground="#4EC9B0" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Min" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding Min, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Max" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding Max, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6" MinHeight="40" />
                    </StackPanel>
                </Grid>
                <CheckBox IsChecked="{Binding ReverseScored}" Content="Reverse scored"
                          Foreground="#CCC" Margin="0,0,0,12"/>
                <TextBlock Text="Labels (optional, one per scale point)" Foreground="#AAA" FontSize="11" Margin="0,0,0,4"/>
                <ListBox ItemsSource="{Binding Labels}"
                         SelectedItem="{Binding DataContext.SelectedChoice, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                         Background="#2A2A2A" BorderBrush="#444" BorderThickness="1"
                         MinHeight="60" MaxHeight="120" Margin="0,0,0,6"/>
                <DockPanel>
                    <Button Content="Remove" Command="{Binding DataContext.RemoveChoiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DockPanel.Dock="Right" Width="70" Height="28" Margin="6,0,0,0"
                            Background="#3A3A3A" Foreground="#E0E0E0" BorderThickness="0"/>
                    <Button Content="Add" Command="{Binding DataContext.AddChoiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DockPanel.Dock="Right" Width="50" Height="28" Margin="6,0,0,0"
                            Background="#007ACC" Foreground="White" BorderThickness="0"/>
                    <TextBox Text="{Binding DataContext.NewChoiceText, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6" MinHeight="40"
                             VerticalContentAlignment="Center"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type domain:MultipleChoiceResponse}">
            <StackPanel>
                <TextBlock Text="Multiple Choice (single select)" Foreground="#4EC9B0" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Choices" Foreground="#AAA" FontSize="11" Margin="0,0,0,4"/>
                <ListBox ItemsSource="{Binding Choices}"
                         SelectedItem="{Binding DataContext.SelectedChoice, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                         Background="#2A2A2A" BorderBrush="#444" BorderThickness="1"
                         MinHeight="80" MaxHeight="160" Margin="0,0,0,6"/>
                <DockPanel>
                    <Button Content="Remove" Command="{Binding DataContext.RemoveChoiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DockPanel.Dock="Right" Width="70" Height="28" Margin="6,0,0,0"
                            Background="#3A3A3A" Foreground="#E0E0E0" BorderThickness="0"/>
                    <Button Content="Add" Command="{Binding DataContext.AddChoiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DockPanel.Dock="Right" Width="50" Height="28" Margin="6,0,0,0"
                            Background="#007ACC" Foreground="White" BorderThickness="0"/>
                    <TextBox Text="{Binding DataContext.NewChoiceText, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6" MinHeight="40"
                             VerticalContentAlignment="Center"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type domain:MultiSelectResponse}">
            <StackPanel>
                <TextBlock Text="Multi-Select" Foreground="#4EC9B0" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Min selections" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding MinSelections, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                 Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Max selections" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding MaxSelections, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                 Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Choices" Foreground="#AAA" FontSize="11" Margin="0,0,0,4"/>
                <ListBox ItemsSource="{Binding Choices}"
                         SelectedItem="{Binding DataContext.SelectedChoice, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                         Background="#2A2A2A" BorderBrush="#444" BorderThickness="1"
                         MinHeight="80" MaxHeight="140" Margin="0,0,0,6"/>
                <DockPanel>
                    <Button Content="Remove" Command="{Binding DataContext.RemoveChoiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DockPanel.Dock="Right" Width="70" Height="28" Margin="6,0,0,0"
                            Background="#3A3A3A" Foreground="#E0E0E0" BorderThickness="0"/>
                    <Button Content="Add" Command="{Binding DataContext.AddChoiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DockPanel.Dock="Right" Width="50" Height="28" Margin="6,0,0,0"
                            Background="#007ACC" Foreground="White" BorderThickness="0"/>
                    <TextBox Text="{Binding DataContext.NewChoiceText, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6" MinHeight="40"
                             VerticalContentAlignment="Center"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type domain:DateResponse}">
            <StackPanel>
                <TextBlock Text="Date Response" Foreground="#4EC9B0" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Min date (yyyy-MM-dd, blank = none)" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding MinDate, Converter={StaticResource DateOnlyToStringConverter}, UpdateSourceTrigger=PropertyChanged}"
                         Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6" Margin="0,0,0,8"/>
                <TextBlock Text="Max date (yyyy-MM-dd, blank = none)" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding MaxDate, Converter={StaticResource DateOnlyToStringConverter}, UpdateSourceTrigger=PropertyChanged}"
                         Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type domain:FixedDigitsResponse}">
            <StackPanel>
                <TextBlock Text="Fixed Digits" Foreground="#4EC9B0" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Number of digits" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding DigitCount, UpdateSourceTrigger=PropertyChanged}"
                         Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6" Width="80"
                         HorizontalAlignment="Left"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type domain:BoundedTextResponse}">
            <StackPanel>
                <TextBlock Text="Bounded Text" Foreground="#4EC9B0" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Min length" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding MinLength, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Max length" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding MaxLength, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type domain:BoundedNumberResponse}">
            <StackPanel>
                <TextBlock Text="Bounded Number" Foreground="#4EC9B0" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Min" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding Min, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                 Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Max" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding Max, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                 Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Decimal places (blank = any)" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding DecimalPlaces, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                         Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6" Width="80"
                         HorizontalAlignment="Left"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type domain:RegexResponse}">
            <StackPanel>
                <TextBlock Text="Regular Expression" Foreground="#4EC9B0" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <TextBlock Text="Pattern" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                         Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6"
                         FontFamily="Consolas" Margin="0,0,0,8"/>
                <TextBlock Text="Validation message (shown on failure)" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding ValidationMessage, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                         Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555" Padding="6"
                         TextWrapping="Wrap" MinHeight="40"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════ LEFT: Survey list ═══════════════ -->
        <Border Grid.Column="0" Background="#1F1F1F" BorderBrush="#333" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock Text="Surveys" FontSize="18" FontWeight="SemiBold" Foreground="White"
                           Margin="16,12,16,8" DockPanel.Dock="Top"/>

                <StackPanel Orientation="Vertical" Margin="12,0,12,12" DockPanel.Dock="Bottom">
                    <Button Content="+ Add Survey"
                            Command="{Binding AddSurveyCommand}"
                            Style="{StaticResource AccentButton}" Height="36"/>
                    <Button Content="Delete Survey"
                            Command="{Binding DeleteSurveyCommand}"
                            Margin="0,8,0,0" Height="36"
                            Background="#3A3A3A" Foreground="#E0E0E0" BorderThickness="0"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Surveys}"
                         SelectedItem="{Binding SelectedSurvey, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0" Margin="8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2A2A2A" CornerRadius="4" Padding="10,8" Margin="0,3">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Foreground="#888" FontSize="11" Margin="0,2,0,0">
                                        <Run Text="{Binding Items.Count, Mode=OneWay}"/>
                                        <Run Text=" items"/>
                                        <Run Text="  ·  "/>
                                        <Run Text="{Binding TimeoutSeconds, Mode=OneWay}"/>
                                        <Run Text="s timeout"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══════════════ CENTER: Survey properties + Items ═══════════════ -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Survey properties card -->
            <Border Grid.Row="0" Background="#252526" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                    BorderBrush="#3C3C3C" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Survey Name" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Grid.Row="1" Grid.Column="0"
                             Text="{Binding SurveyName, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555"
                             Padding="8,6" Margin="0,0,12,0"
                             IsEnabled="{Binding SelectedSurvey, Converter={StaticResource NullToBoolConverter}, FallbackValue=False}"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Timeout (sec)" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555"
                             Padding="8,6" Margin="0,0,12,0"
                             IsEnabled="{Binding SelectedSurvey, Converter={StaticResource NullToBoolConverter}, FallbackValue=False}"/>

                    <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding AllQuestionsOptional}"
                                  VerticalAlignment="Center"
                                  IsEnabled="{Binding SelectedSurvey, Converter={StaticResource NullToBoolConverter}, FallbackValue=False}"/>
                        <TextBlock Text="All optional" Foreground="#CCC" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Items list -->
            <Border Grid.Row="1" Background="#252526" CornerRadius="6"
                    BorderBrush="#3C3C3C" BorderThickness="1">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="12,10,12,6">
                        <TextBlock Text="Items" FontSize="15" FontWeight="SemiBold" Foreground="White"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="↑" Command="{Binding MoveItemUpCommand}" Width="28" Height="28" Margin="0,0,4,0"
                                    Background="#333" Foreground="#CCC" BorderThickness="0" ToolTip="Move up"/>
                            <Button Content="↓" Command="{Binding MoveItemDownCommand}" Width="28" Height="28" Margin="0,0,8,0"
                                    Background="#333" Foreground="#CCC" BorderThickness="0" ToolTip="Move down"/>
                            <Button Content="+ Header" Command="{Binding AddHeaderCommand}"
                                    Height="28" Padding="10,0" Margin="0,0,4,0"
                                    Background="#3A3A3A" Foreground="#E0E0E0" BorderThickness="0"/>
                            <Button Content="+ Instruction" Command="{Binding AddInstructionCommand}"
                                    Height="28" Padding="10,0" Margin="0,0,4,0"
                                    Background="#3A3A3A" Foreground="#E0E0E0" BorderThickness="0"/>
                            <Button Content="+ Question" Command="{Binding AddQuestionCommand}"
                                    Style="{StaticResource AccentButton}" Height="28" Padding="10,0" Margin="0,0,4,0"/>
                            <Button Content="+ Image" Command="{Binding AddImageCommand}"
                                    Height="28" Padding="10,0"
                                    Background="#3A3A3A" Foreground="#E0E0E0" BorderThickness="0"/>
                        </StackPanel>
                    </DockPanel>

                    <Button Content="Delete Item" Command="{Binding DeleteItemCommand}"
                            DockPanel.Dock="Bottom" Margin="12,8,12,12" Height="32"
                            Background="#3A3A3A" Foreground="#E0E0E0" BorderThickness="0"/>

                    <ListBox ItemsSource="{Binding SelectedSurvey.Items}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <!-- DataTemplates in Resources handle rendering -->
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══════════════ RIGHT: Selected item editor ═══════════════ -->
        <Border Grid.Column="2" Background="#1F1F1F" BorderBrush="#333" BorderThickness="1,0,0,0">
            <DockPanel>
                <TextBlock Text="Item Properties" FontSize="16" FontWeight="SemiBold" Foreground="White"
                           Margin="16,12,16,8" DockPanel.Dock="Top"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,0,12,12">
                    <StackPanel>
                        <!-- Common text field (Header / Instruction / Question) -->
                        <TextBlock Text="Text" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"
                                   Visibility="{Binding ShowItemTextEditor, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBox Text="{Binding ItemText, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"
                                 Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#555"
                                 Padding="8" Margin="0,0,0,12"
                                 Visibility="{Binding ShowItemTextEditor, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Optional override (questions only) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16"
                                    Visibility="{Binding ItemIsOptional, Converter={StaticResource NullToVisibilityConverter}}">
                            <CheckBox IsChecked="{Binding ItemIsOptional}" VerticalAlignment="Center"/>
                            <TextBlock Text="This question is optional (overrides survey default)"
                                       Foreground="#CCC" Margin="6,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Response type selector (questions only) -->
                        <TextBlock Text="Response Type" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"
                                   Visibility="{Binding CurrentResponse, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <ComboBox SelectedValue="{Binding SelectedResponseType}"
                                  SelectedValuePath="Content"
                                  Style="{StaticResource DarkComboBox}"
                                  Margin="0,0,0,12"
                                  Visibility="{Binding CurrentResponse, Converter={StaticResource NullToVisibilityConverter}}">
                            <ComboBoxItem Content="Likert"/>
                            <ComboBoxItem Content="MultipleChoice"/>
                            <ComboBoxItem Content="MultiSelect"/>
                            <ComboBoxItem Content="Date"/>
                            <ComboBoxItem Content="FixedDigits"/>
                            <ComboBoxItem Content="BoundedText"/>
                            <ComboBoxItem Content="BoundedNumber"/>
                            <ComboBoxItem Content="Regex"/>
                        </ComboBox>

                        <!-- Apply type change -->
                        <Button Content="Apply Response Type"
                                Command="{Binding ChangeResponseTypeCommand}"
                                CommandParameter="{Binding SelectedResponseType}"
                                Style="{StaticResource AccentButton}" Height="32" Margin="0,0,0,16"
                                Visibility="{Binding CurrentResponse, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <!-- Type-specific response editor (implicit DataTemplates above) -->
                        <Border Background="#252526" CornerRadius="4" Padding="12"
                                Visibility="{Binding CurrentResponse, Converter={StaticResource NullToVisibilityConverter}}">
                            <ContentControl Content="{Binding CurrentResponse}"/>
                        </Border>

                        <!-- Image item editor -->
                        <StackPanel Visibility="{Binding IsImageItemSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Survey Image" Foreground="#C586C0" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding CurrentImageFileName}" Foreground="#AAA" FontSize="12"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>
                            <Border Background="#2A2A2A" CornerRadius="4" Padding="8" Margin="0,0,0,12"
                                    HorizontalAlignment="Left">
                                <Image Source="{Binding CurrentImagePreview}"
                                       MaxWidth="280" MaxHeight="200"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <Button Content="Change Image…"
                                    Command="{Binding ChangeImageCommand}"
                                    Style="{StaticResource AccentButton}"
                                    Height="32" HorizontalAlignment="Left" Padding="16,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
