<UserControl x:Class="IAT.Views.Controls.LayoutEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#1E1E1E">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="ResizeThumbStyle" TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="IsEnabled" Value="{Binding IsLayoutEditMode}"/>
            <Setter Property="IsHitTestVisible" Value="{Binding IsLayoutEditMode}"/>
            <!-- Fully hidden unless Edit Mode is on — not merely disabled -->
            <Setter Property="Visibility" Value="{Binding IsLayoutEditMode, Converter={StaticResource BoolToVis}}"/>
            <Setter Property="Opacity" Value="0.95"/>
            <Setter Property="Panel.ZIndex" Value="10"/>
            <Setter Property="Cursor" Value="SizeAll"/>
            <EventSetter Event="DragDelta" Handler="OnResizeThumbDragDelta"/>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnThumbPreviewMouseLeftButtonDown"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- CENTER: Editable preview -->
        <Grid Grid.Column="0" Margin="16" SizeChanged="OnPreviewHostSizeChanged">
            <Border Background="White" CornerRadius="4" Padding="20" Effect="{StaticResource DropShadow}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas x:Name="PreviewCanvas"
                        Background="#F8F8F8"
                        Width="{Binding InteriorWidth}"
                        Height="{Binding InteriorHeight}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas.RenderTransform>
                        <ScaleTransform ScaleX="{Binding ScaleFactor}" ScaleY="{Binding ScaleFactor}"
                                        CenterX="{Binding InteriorWidth, Converter={StaticResource HalfValueConverter}}"
                                        CenterY="{Binding InteriorHeight, Converter={StaticResource HalfValueConverter}}" />
                    </Canvas.RenderTransform>

                    <!-- Block Instructions -->
                    <Border Canvas.Left="{Binding BlockInstructionsX}"
                            Canvas.Top="{Binding BlockInstructionsY}"
                            Width="{Binding BlockInstructionsWidth}"
                            Height="{Binding BlockInstructionsHeight}"
                            BorderThickness="2" CornerRadius="4"
                            ClipToBounds="False"
                            Tag="BlockInstructions"
                            Cursor="SizeAll"
                            BorderBrush="{Binding IsLayoutEditMode, Converter={StaticResource BoolToBorderBrushConverter}}"
                            PreviewMouseLeftButtonDown="OnElementMouseLeftButtonDown"
                            MouseMove="OnElementMouseMove"
                            PreviewMouseLeftButtonUp="OnElementMouseLeftButtonUp">
                        <Grid>
                            <TextBlock Text="Block Instructions" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" Foreground="#000"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Top"
                                              Margin="-5,-5,0,0" Cursor="SizeNWSE" Tag="BlockInstructions_NW"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                              Margin="0,-5,-5,0" Cursor="SizeNESW" Tag="BlockInstructions_NE"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                              Margin="-5,0,0,-5" Cursor="SizeNESW" Tag="BlockInstructions_SW"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                              Margin="0,0,-5,-5" Cursor="SizeNWSE" Tag="BlockInstructions_SE"/>
                        </Grid>
                    </Border>

                    <!-- Stimulus -->
                    <Border Canvas.Left="{Binding StimulusX}"
                            Canvas.Top="{Binding StimulusY}"
                            Width="{Binding StimulusWidth}"
                            Height="{Binding StimulusHeight}"
                            BorderThickness="3" CornerRadius="8"
                            ClipToBounds="False"
                            Tag="Stimulus"
                            Cursor="SizeAll"
                            BorderBrush="{Binding IsLayoutEditMode, Converter={StaticResource BoolToBorderBrushConverter}}"
                            PreviewMouseLeftButtonDown="OnElementMouseLeftButtonDown"
                            MouseMove="OnElementMouseMove"
                            PreviewMouseLeftButtonUp="OnElementMouseLeftButtonUp">
                        <Grid>
                            <TextBlock Text="Sample Stimulus" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" FontWeight="Medium" Foreground="#555"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Top"
                                              Margin="-5,-5,0,0" Cursor="SizeNWSE" Tag="Stimulus_NW"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                              Margin="0,-5,-5,0" Cursor="SizeNESW" Tag="Stimulus_NE"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                              Margin="-5,0,0,-5" Cursor="SizeNESW" Tag="Stimulus_SW"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                              Margin="0,0,-5,-5" Cursor="SizeNWSE" Tag="Stimulus_SE"/>
                        </Grid>
                    </Border>

                    <!-- Left Key -->
                    <Border Canvas.Left="{Binding LeftKeyX}"
                            Canvas.Top="{Binding LeftKeyY}"
                            Width="{Binding KeyWidth}"
                            Height="{Binding KeyHeight}"
                            BorderThickness="2"
                            ClipToBounds="False"
                            Tag="LeftKey"
                            Cursor="SizeAll"
                            BorderBrush="{Binding IsLayoutEditMode, Converter={StaticResource BoolToBorderBrushConverter}}"
                            PreviewMouseLeftButtonDown="OnElementMouseLeftButtonDown"
                            MouseMove="OnElementMouseMove"
                            PreviewMouseLeftButtonUp="OnElementMouseLeftButtonUp">
                        <Grid>
                            <TextBlock Text="Left Key (E)" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Top"
                                              Margin="-5,-5,0,0" Cursor="SizeNWSE" Tag="LeftKey_NW"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                              Margin="0,-5,-5,0" Cursor="SizeNESW" Tag="LeftKey_NE"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                              Margin="-5,0,0,-5" Cursor="SizeNESW" Tag="LeftKey_SW"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                              Margin="0,0,-5,-5" Cursor="SizeNWSE" Tag="LeftKey_SE"/>
                        </Grid>
                    </Border>

                    <!-- Right Key -->
                    <Border Canvas.Left="{Binding RightKeyX}"
                            Canvas.Top="{Binding RightKeyY}"
                            Width="{Binding KeyWidth}"
                            Height="{Binding KeyHeight}"
                            BorderThickness="2"
                            ClipToBounds="False"
                            Tag="RightKey"
                            Cursor="SizeAll"
                            BorderBrush="{Binding IsLayoutEditMode, Converter={StaticResource BoolToBorderBrushConverter}}"
                            PreviewMouseLeftButtonDown="OnElementMouseLeftButtonDown"
                            MouseMove="OnElementMouseMove"
                            PreviewMouseLeftButtonUp="OnElementMouseLeftButtonUp">
                        <Grid>
                            <TextBlock Text="Right Key (I)" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Top"
                                              Margin="-5,-5,0,0" Cursor="SizeNWSE" Tag="RightKey_NW"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                              Margin="0,-5,-5,0" Cursor="SizeNESW" Tag="RightKey_NE"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                              Margin="-5,0,0,-5" Cursor="SizeNESW" Tag="RightKey_SW"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                              Margin="0,0,-5,-5" Cursor="SizeNWSE" Tag="RightKey_SE"/>
                        </Grid>
                    </Border>

                    <!-- Error Mark -->
                    <Border Canvas.Left="{Binding ErrorMarkX}"
                            Canvas.Top="{Binding ErrorMarkY}"
                            Width="{Binding ErrorMarkWidth}"
                            Height="{Binding ErrorMarkHeight}"
                            BorderThickness="2"
                            ClipToBounds="False"
                            Tag="ErrorMark"
                            Cursor="SizeAll"
                            BorderBrush="{Binding IsLayoutEditMode, Converter={StaticResource BoolToBorderBrushConverter}}"
                            PreviewMouseLeftButtonDown="OnElementMouseLeftButtonDown"
                            MouseMove="OnElementMouseMove"
                            PreviewMouseLeftButtonUp="OnElementMouseLeftButtonUp">
                        <Grid>
                            <TextBlock Text="X" Foreground="Red" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Top"
                                              Margin="-5,-5,0,0" Cursor="SizeNWSE" Tag="ErrorMark_NW"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                              Margin="0,-5,-5,0" Cursor="SizeNESW" Tag="ErrorMark_NE"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                              Margin="-5,0,0,-5" Cursor="SizeNESW" Tag="ErrorMark_SW"/>
                            <primitives:Thumb Style="{StaticResource ResizeThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                              Margin="0,0,-5,-5" Cursor="SizeNWSE" Tag="ErrorMark_SE"/>
                        </Grid>
                    </Border>
                </Canvas>
            </Border>
        </Grid>

        <!-- RIGHT: Stage size + save -->
        <Border Grid.Column="1" Background="#1F1F1F" Padding="16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Layout" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16"/>

                    <ToggleButton Content="Edit Mode"
                                  IsChecked="{Binding IsLayoutEditMode, Mode=TwoWay}"
                                  Margin="0,0,0,16" Padding="12,6"
                                  Background="#007ACC" Foreground="White" FontWeight="SemiBold"
                                  BorderThickness="0" Cursor="Hand"
                                  ToolTip="Show blue borders and enable drag / resize"/>

                    <TextBlock Text="Preview Stage Size" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,8"/>
                    <TextBlock Text="Logical size (px). On-screen frame stays stable; elements move outward or toward center. Change Width vs Height to alter aspect ratio."
                               Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Label Content="Interior Width" Foreground="White" Padding="0"/>
                    <DockPanel Margin="0,0,0,8">
                        <TextBox Width="70" DockPanel.Dock="Right"
                                 Text="{Binding InteriorWidth, UpdateSourceTrigger=LostFocus}"
                                 Style="{StaticResource DarkTextBox}"/>
                        <Slider Minimum="300" Maximum="1600" TickFrequency="10" IsSnapToTickEnabled="True"
                                Value="{Binding InteriorWidth, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                    </DockPanel>

                    <Label Content="Interior Height" Foreground="White" Padding="0"/>
                    <DockPanel Margin="0,0,0,8">
                        <TextBox Width="70" DockPanel.Dock="Right"
                                 Text="{Binding InteriorHeight, UpdateSourceTrigger=LostFocus}"
                                 Style="{StaticResource DarkTextBox}"/>
                        <Slider Minimum="300" Maximum="1600" TickFrequency="10" IsSnapToTickEnabled="True"
                                Value="{Binding InteriorHeight, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                    </DockPanel>

                    <TextBlock Foreground="#00BFA5" FontSize="12" Margin="0,4,0,0">
                        <Run Text="Stage "/>
                        <Run Text="{Binding InteriorWidth, Mode=OneWay, StringFormat={}{0:0}}"/>
                        <Run Text=" × "/>
                        <Run Text="{Binding InteriorHeight, Mode=OneWay, StringFormat={}{0:0}}"/>
                        <Run Text=" px"/>
                    </TextBlock>

                    <TextBlock Text="Drag elements to move. Drag blue corner thumbs to resize (center stays fixed)."
                               Foreground="#888888" FontSize="11" TextWrapping="Wrap" Margin="0,16,0,0"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#00BFA5" FontSize="12" TextWrapping="Wrap" Margin="0,16,0,0"/>
                </StackPanel>

                <Button Content="Save Layout"
                        Command="{Binding SaveLayoutCommand}"
                        Style="{StaticResource AccentButton}"
                        Height="40" Margin="0,16,0,0"
                        VerticalAlignment="Bottom"
                        DockPanel.Dock="Bottom"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
