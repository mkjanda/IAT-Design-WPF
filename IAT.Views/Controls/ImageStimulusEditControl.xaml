<UserControl x:Class="IAT.Views.Controls.ImageStimulusEditControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="520"
             Background="#252526">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="Auto"/>
            <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Edit Image Stimulus" 
                       FontSize="18" FontWeight="SemiBold" 
                       Foreground="#FFFFFF" VerticalAlignment="Center"/>
            <Button Content="✕" 
                    HorizontalAlignment="Right"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#888888" FontSize="20"
                    Width="32" Height="32"
                    Command="{Binding CloseCommand}"/>
        </DockPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <!-- Image Preview -->
                <RowDefinition Height="Auto"/>
                <!-- File Info -->
                <RowDefinition Height="Auto"/>
                <!-- Alt Text -->
            </Grid.RowDefinitions>

            <!-- Image Preview + Change Button -->
            <Border Grid.Row="0" 
                    Background="#1E1E1E" 
                    BorderBrush="#444" BorderThickness="1"
                    CornerRadius="6" Padding="8" Margin="0,0,0,16">
                <Grid>
                    <Image Source="{Binding PreviewImage}" 
                           Stretch="Uniform" />
                    <Button Content="Change Image..." 
                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,12"
                            Width="160" Height="36"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ChangeImageCommand}"/>
                </Grid>
            </Border>

            <!-- File Metadata -->
            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Text="Filename" FontSize="12" Foreground="#AAAAAA"/>
                <TextBlock Text="{Binding FileName}" Foreground="#E0E0E0" FontSize="13" Margin="0,0,0,8"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Dimensions" FontSize="12" Foreground="#AAAAAA"/>
                        <TextBlock Text="{Binding Dimensions}" Foreground="#E0E0E0" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="File Size" FontSize="12" Foreground="#AAAAAA"/>
                        <TextBlock Text="{Binding FileSize}" Foreground="#E0E0E0" FontSize="13"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Alt Text / Description -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="Alt Text / Description" FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                <TextBox Text="{Binding AltText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         Height="80"/>
            </StackPanel>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Width="100" Height="38" Margin="0,0,8,0"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding SaveCommand}"/>
            <Button Content="Delete Stimulus" Width="140" Height="38" Margin="0,0,8,0"
                    Background="#3C3C3C" Foreground="#E0E0E0"
                    Command="{Binding DeleteCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>