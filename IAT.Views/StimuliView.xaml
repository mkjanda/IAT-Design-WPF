<UserControl x:Class="IAT.Views.StimuliView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:IAT.ViewModels.Controls;assembly=IAT.ViewModels"
             xmlns:domain="clr-namespace:IAT.Core.Domain;assembly=IAT.Core"
             mc:Ignorable="d" d:DesignHeight="650" d:DesignWidth="1100">
    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Stimuli Library -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E5E5E5" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16">
                    <TextBlock Text="Stimuli Library" FontSize="18" FontWeight="SemiBold"/>
                    <!--<TextBox Margin="0,12,0,0" Height="36" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Search stimuli..."
                             />-->
                    <Button Content="+ Add Text Stimulus" 
                            Command="{Binding AddTextStimulusCommand}"
                            Margin="0,16,0,8" Height="40" Style="{StaticResource AccentButton}"/>
                    <Button Content="+ Add Image Stimulus" 
                            Command="{Binding AddImageStimulusCommand}"
                            Height="40" Style="{StaticResource AccentButton}"/>
                </StackPanel>

                <ListView ItemsSource="{Binding Stimuli}" 
                          SelectedItem="{Binding SelectedStimulus}"
                          Margin="8" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <Border Width="56" Height="56" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1">
                                    <!-- Thumbnail preview (you can bind ImageSource here later) -->
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Phrase}" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Type.Name}" Foreground="#666" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>

        <!-- RIGHT: Editor + Live Preview -->
        <Grid Grid.Column="1" Margin="24">
            <StackPanel>
                <TextBlock Text="Edit Selected Stimulus" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <ContentControl Content="{Binding SelectedStimulus}">
                    <ContentControl.Resources>
                        <!-- Text Stimulus Editor -->
                        <DataTemplate DataType="{x:Type domain:TextStimulus}">
                            <StackPanel>
                                <Label Content="Phrase"/>
                                <TextBox Text="{Binding Phrase, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="100" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                                <Grid Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <Label Content="Font Family"/>
                                        <ComboBox SelectedValue="{Binding PhraseFontFamily}" Width="200"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                        <Label Content="Font Size"/>
                                        <TextBox Text="{Binding PhraseFontSize}" Width="80"/>
                                    </StackPanel>
                                </Grid>

                                <Label Content="Live Preview (exactly as participant will see it)" Margin="0,24,0,8" FontWeight="Medium"/>
                                <Border BorderBrush="#CCC" BorderThickness="2" Background="White" Padding="30" HorizontalAlignment="Center">
                                    <Image Source="{Binding DataContext.LivePreview, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                           Width="420" MaxHeight="160"/>
                                </Border>
                            </StackPanel>
                        </DataTemplate>

                        <!-- Image Stimulus Editor (expand later) -->
                        <DataTemplate DataType="{x:Type domain:ImageStimulus}">
                            <StackPanel>
                                <Label Content="Image Stimulus"/>
                                <Border Width="420" Height="240" Background="#FAFAFA" BorderBrush="#CCC" BorderThickness="2">
                                    <Image Source="{Binding DataContext.LivePreview, RelativeSource={RelativeSource AncestorType=UserControl}}" Stretch="Uniform"/>
                                </Border>
                                <Button Content="Replace Image" Margin="0,16,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
<!--                    <Button Content="Delete Stimulus" Command="{Binding DeleteStimulusCommand}" 
    S                        Style="{StaticResource DestructiveButtonStyle}" Margin="0,0,12,0"/>-->
                    <Button Content="Save &amp; Close" Command="{Binding SaveCommand}" IsDefault="True"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>