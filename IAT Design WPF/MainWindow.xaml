<Window x:Class="IAT_Design_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:IAT.Views.Controls;assembly=IAT.Views"
        mc:Ignorable="d"
        Title="IAT Designer - My First Test"
        Height="720" Width="1280"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <!-- 
            Single-cell layout: TabControl fills the entire available height (* from parent Window).
            This allows tab contents to scale vertically to the window size.
            ErrorBanner is overlaid via Z-order (declared after TabControl) and positioned below tab headers.
        -->
    
        <TabControl Background="#252526" BorderThickness="0" 
                    SelectedIndex="1" VerticalAlignment="Stretch"
                    Style="{StaticResource ModernTabControlStyle}">
            <TabItem Header="Blocks" FontSize="18" Width="70" Foreground="#F7C46C">
                <controls:BlockEditView Name="BlockEditView" DataContext="{Binding BlockEditor}" />
            </TabItem>

            <TabItem Header="Stimuli" FontSize="18" Width="70" Foreground="#F7C46C">
                <controls:StimuliManagerControl x:Name="StimuliManager" DataContext="{Binding StimuliManager}" />
            </TabItem>

            <TabItem Header="Trials" FontSize="18" Width="70" Foreground="#F7C46C"/>
            <TabItem Header="Deploy" FontSize="18" Width="70" Foreground="#F7C46C"/>
        </TabControl>

        <!-- Error banner overlaid on the tab content (Z-order places it above the TabControl content).
             Margin top value positions it just below the tab strip (~ tab header height).
             The animation slides it into the top of the current tab page without affecting the tab content's allocated height. -->
        <controls:ErrorBannerControl x:Name="ErrorBanner"
                                     VerticalAlignment="Top"
                                     Margin="8,42,8,0"
                                     RenderTransformOrigin="0.5,0"
                                     RenderTransform="{StaticResource TranslateTransformZero}"/>
    </Grid>
</Window>