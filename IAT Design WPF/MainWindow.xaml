<Window x:Class="IAT_Design_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:IAT.Views.Controls;assembly=IAT.Views"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="720" Width="1280"
        Background="#252526"
        Foreground="#E0E0E0"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        Closing="OnWindowClosing">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCommand}"/>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveAsCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- File toolbar -->
        <Border Grid.Row="0" Background="#2D2D2D" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <Button Content="New" Command="{Binding NewCommand}"
                        Style="{StaticResource AccentButton}"
                        Padding="14,6" Margin="0,0,6,0" Height="24" Width="60"
                        ToolTip="New project (Ctrl+N)"/>
                <Button Content="Open" Command="{Binding OpenCommand}"
                        Style="{StaticResource AccentButton}"
                        Padding="14,6" Margin="0,0,6,0" Height="24" Width="60"      
                        ToolTip="Open project (Ctrl+O)"/>
                <Button Content="Save" Command="{Binding SaveCommand}" Width="60"
                        Style="{StaticResource AccentButton}"
                        Padding="14,6" Margin="0,0,6,0" Height="24" 
                        ToolTip="Save project (Ctrl+S)"/>
                <Button Content="Save As" Command="{Binding SaveAsCommand}"
                        Style="{StaticResource AccentButton}"
                        Padding="14,6" Height="24" Width="60"
                        ToolTip="Save project as… (Ctrl+Shift+S)"/>
            </StackPanel>
        </Border>

        <!-- Tabs + error banner -->
        <Grid Grid.Row="1">
            <TabControl Background="#252526" BorderThickness="0"
                        SelectedIndex="0" VerticalAlignment="Stretch"
                        Style="{StaticResource ModernTabControlStyle}">
                <TabItem Header="Blocks" FontSize="18" Width="70" Foreground="#F7C46C">
                    <controls:BlockEditView Name="BlockEditView" DataContext="{Binding BlockEditor}" />
                </TabItem>

                <TabItem Header="Layout" FontSize="18" Width="70" Foreground="#F7C46C">
                    <controls:LayoutEditView DataContext="{Binding LayoutEditor}" />
                </TabItem>

                <TabItem Header="Stimuli" FontSize="18" Width="70" Foreground="#F7C46C">
                    <controls:StimuliManagerControl x:Name="StimuliManager" DataContext="{Binding StimuliManager}" />
                </TabItem>

                <TabItem Header="Trials" FontSize="18" Width="70" Foreground="#F7C46C">
                    <controls:TrialsManagerControl x:Name="TrialsManager" DataContext="{Binding TrialsManager}" />
                </TabItem>

                <TabItem Header="Deploy" FontSize="18" Width="70" Foreground="#F7C46C"/>
            </TabControl>

            <controls:ErrorBannerControl x:Name="ErrorBanner"
                                         VerticalAlignment="Top"
                                         Margin="8,42,8,0"
                                         RenderTransformOrigin="0.5,0"
                                         RenderTransform="{StaticResource TranslateTransformZero}"/>
        </Grid>
    </Grid>
</Window>
